# Simple Dockerfile that serves pre-built Flutter web app
FROM nginx:alpine

# Copy the pre-built web files from your local build
COPY build/web /usr/share/nginx/html

# Copy nginx configuration with CORS headers
COPY nginx/cors.conf /etc/nginx/conf.d/default.conf

# Add build info
RUN echo "Build Date: $(date)" > /usr/share/nginx/html/build_info.txt

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
